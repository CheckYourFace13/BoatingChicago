# Environment variables for Boating Chicago

# Site URL (used for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://boatingchicago.com

# Contact email displayed in footer
CONTACT_EMAIL=hello@boatingchicago.com

# Lead notification email (required for production)
LEADS_TO_EMAIL=hello@boatingchicago.com
FROM_EMAIL=Boating Chicago <hello@boatingchicago.com>
RESEND_API_KEY=

# Optional: use SendGrid instead of Resend
# SENDGRID_API_KEY=

# Affiliate partner links
# GetYourGuide is the only active provider (partner ID HISQ5ML)
NEXT_PUBLIC_AFFILIATE_GETYOURGUIDE=https://www.getyourguide.com/chicago-l225/?partner_id=HISQ5ML&utm_medium=online_publisher&cmp=Boating

# Inactive until approved tracking links are provided (kept for future use)
