# Environment variables for Boating Chicago

# Site URL (used for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://boatingchicago.com

# Contact email displayed in footer
CONTACT_EMAIL=hello@boatingchicago.com

# Lead notification email (required for production)
LEADS_TO_EMAIL=hello@boatingchicago.com
FROM_EMAIL=Boating Chicago <hello@boatingchicago.com>
RESEND_API_KEY=

# Optional: use SendGrid instead of Resend
# SENDGRID_API_KEY=

# Affiliate partner links
# Active: GetYourGuide (HISQ5ML) + Viator (P00309183)
NEXT_PUBLIC_AFFILIATE_GETYOURGUIDE=https://www.getyourguide.com/chicago-l225/?partner_id=HISQ5ML&utm_medium=online_publisher&cmp=Boating
NEXT_PUBLIC_AFFILIATE_VIATOR=https://www.viator.com/Chicago-attractions/Chicago-River/d673-a1219?pid=P00309183&mcid=42383&medium=link

# Inactive until approved tracking links are provided (kept for future use)
# NEXT_PUBLIC_AFFILIATE_BOATSETTER=
# NEXT_PUBLIC_AFFILIATE_GETMYBOAT=
# NEXT_PUBLIC_AFFILIATE_FISHINGBOOKER=
# NEXT_PUBLIC_AFFILIATE_CUSTOM=

# Viator API (future only — do NOT prefix with NEXT_PUBLIC; never expose in client code)
VIATOR_API_KEY=
VIATOR_API_MODE=disabled

# Google Analytics 4 (leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google AdSense (leave empty to disable script + units)
NEXT_PUBLIC_ADSENSE_CLIENT=
# Optional unit slot IDs from AdSense (AdSenseBlock renders nothing without these)
# NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE_TOP=
# NEXT_PUBLIC_ADSENSE_SLOT_GUIDE_MID=
# NEXT_PUBLIC_ADSENSE_SLOT_GUIDE_BOTTOM=

# Future analytics (inactive until configured — do not enable without review)
# NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
# NEXT_PUBLIC_CLARITY_PROJECT_ID=
# NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Optional: newsletter platform sync
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=
